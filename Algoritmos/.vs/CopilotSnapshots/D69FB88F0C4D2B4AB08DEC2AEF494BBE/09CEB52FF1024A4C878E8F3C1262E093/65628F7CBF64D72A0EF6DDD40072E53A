using System;
using System.Collections.Generic;
using System.Drawing;
using System.Windows.Forms;

namespace Algoritmos
{
    public class FormDDA : Form
    {
        private float x1 = 0, y1 = 0;
        private float x2 = 0, y2 = 0;
        private bool drawLine = false;

        private TextBox txtX1;
        private TextBox txtY1;
        private TextBox txtX2;
        private TextBox txtY2;
        private Button btnDibujar;
        private Panel panelDibujo;
        private DataGridView dataGridViewDDA;
        
        // Puntos precalculados para el dibujo
        private List<Point> puntosLinea = new List<Point>();

        public FormDDA()
        {
            this.Text = "Algoritmo DDA con Cuadrícula y Tabla";
            this.Size = new Size(950, 550);
            this.BackColor = Color.FromArgb(245, 246, 250);
            this.Font = new Font("Segoe UI", 9F, FontStyle.Regular, GraphicsUnit.Point);

            Label lblX1 = new Label() { Text = "X1:", Location = new Point(10, 20), Width = 30 };
            txtX1 = new TextBox() { Location = new Point(40, 15), Width = 50, Text = "50" };

            Label lblY1 = new Label() { Text = "Y1:", Location = new Point(100, 20), Width = 30 };
            txtY1 = new TextBox() { Location = new Point(130, 15), Width = 50, Text = "50" };

            Label lblX2 = new Label() { Text = "X2:", Location = new Point(200, 20), Width = 30 };
            txtX2 = new TextBox() { Location = new Point(230, 15), Width = 50, Text = "300" };

            Label lblY2 = new Label() { Text = "Y2:", Location = new Point(300, 20), Width = 30 };
            txtY2 = new TextBox() { Location = new Point(330, 15), Width = 50, Text = "250" };

            btnDibujar = new Button() { 
                Text = "Dibujar DDA", 
                Location = new Point(400, 13), 
                Width = 100,
                Height = 30,
                FlatStyle = FlatStyle.Flat,
                BackColor = Color.FromArgb(76, 175, 80), // Verde moderno
                ForeColor = Color.White,
                Cursor = Cursors.Hand
            };
            btnDibujar.FlatAppearance.BorderSize = 0;
            btnDibujar.Click += BtnDibujar_Click;

            panelDibujo = new Panel()
            {
                Location = new Point(10, 60),
                Size = new Size(450, 430),
                BackColor = Color.White,
                BorderStyle = BorderStyle.FixedSingle
            };
            panelDibujo.Paint += PanelDibujo_Paint;

            dataGridViewDDA = new DataGridView()
            {
                Location = new Point(470, 60),
                Size = new Size(450, 430),
                ReadOnly = true,
                AllowUserToAddRows = false,
                RowHeadersVisible = false,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                BackgroundColor = Color.White,
                BorderStyle = BorderStyle.None,
                EnableHeadersVisualStyles = false
            };
            
            dataGridViewDDA.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(76, 175, 80);
            dataGridViewDDA.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dataGridViewDDA.AlternatingRowsDefaultCellStyle.BackColor = Color.FromArgb(245, 245, 245);

            dataGridViewDDA.Columns.Add("K", "Iteración (k)");
            dataGridViewDDA.Columns.Add("X", "X");
            dataGridViewDDA.Columns.Add("Y", "Y");
            dataGridViewDDA.Columns.Add("XRound", "X Redondeado");
            dataGridViewDDA.Columns.Add("YRound", "Y Redondeado");

            this.Controls.Add(lblX1);
            this.Controls.Add(txtX1);
            this.Controls.Add(lblY1);
            this.Controls.Add(txtY1);
            this.Controls.Add(lblX2);
            this.Controls.Add(txtX2);
            this.Controls.Add(lblY2);
            this.Controls.Add(txtY2);
            this.Controls.Add(btnDibujar);
            this.Controls.Add(panelDibujo);
            this.Controls.Add(dataGridViewDDA);
        }

        private void BtnDibujar_Click(object? sender, EventArgs e)
        {
            if (float.TryParse(txtX1.Text, out x1) && float.TryParse(txtY1.Text, out y1) &&
                float.TryParse(txtX2.Text, out x2) && float.TryParse(txtY2.Text, out y2))
            {
                CalcularDDA();
                drawLine = true;
                panelDibujo.Invalidate(); 
            }
            else
            {
                MessageBox.Show("Por favor, ingrese valores numéricos válidos en las coordenadas.");
            }
        }

        private void CalcularDDA()
        {
            dataGridViewDDA.Rows.Clear();
            puntosLinea.Clear();

            float dx = x2 - x1;
            float dy = y2 - y1;

            float steps = Math.Max(Math.Abs(dx), Math.Abs(dy));

            float xInc = dx / steps;
            float yInc = dy / steps;

            float x = x1;
            float y = y1;

            if (steps == 0) return; // Prevent infinite loops or zero divide if point is the same

            for (int k = 0; k <= steps; k++)
            {
                int xRound = (int)Math.Round(x);
                int yRound = (int)Math.Round(y);

                puntosLinea.Add(new Point(xRound, yRound));
                
                dataGridViewDDA.Rows.Add(k, x.ToString("F2"), y.ToString("F2"), xRound, yRound);

                x += xInc;
                y += yInc;
            }
        }

        private void PanelDibujo_Paint(object? sender, PaintEventArgs e)
        {
            Graphics g = e.Graphics;
            g.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.AntiAlias;
            int gridSize = 10; 

            // Dibujar Cuadrícula
            Pen gridPen = new Pen(Color.FromArgb(220,220,220), 1) { DashStyle = System.Drawing.Drawing2D.DashStyle.Dot };
            for (int i = 0; i < panelDibujo.Width; i += gridSize)
            {
                g.DrawLine(gridPen, i, 0, i, panelDibujo.Height);
            }
            for (int i = 0; i < panelDibujo.Height; i += gridSize)
            {
                g.DrawLine(gridPen, 0, i, panelDibujo.Width, i);
            }

            // Dibujar Línea DDA
            if (!drawLine || puntosLinea.Count == 0) return;

            Brush brush = new SolidBrush(Color.FromArgb(76, 175, 80)); // Verde
            foreach (var point in puntosLinea)
            {
                g.FillRectangle(brush, point.X, point.Y, 3, 3);
            }
        }
    }
}